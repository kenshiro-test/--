{"parks": {"sea": {"plans": {}, "masterEvents": [{"id": 7, "area": "メディテレーニアンハーバー", "name": "ビリーヴ！～シー・オブ・ドリームス～", "times": ["19:30"], "duration": 30, "features": "屋外", "imageUrl": "/assets/show-images/believe-sea-of-dreams.png", "isLottery": false, "description": "ディズニーの仲間たちが、あきらめずに信じ続けることで夢を叶えていく、ナイトタイムエンターテイメント。水上での大きな船のダイナミックな展開、夜空を彩るレーザーやパイロ、大規模なプロジェクションマッピングなど、メディテレーニアンハーバーの広大な空間を最大限に活用した演出をお楽しみいただけます。", "officialUrl": "https://www.tokyodisneyresort.jp/tds/show/detail/967/"}, {"id": 12, "area": "パークワイド", "name": "スカイ・フル・オブ・カラーズ", "times": ["20:30"], "duration": 5, "features": "屋外、雨の日も実施", "imageUrl": "/assets/show-images/sky-full-of-colors.png", "isLottery": false, "description": "おなじみのディズニーソングにのせて、色とりどりの花火が夜空に咲きほこります。夢にあふれたひとときをお楽しみください。", "officialUrl": "https://www.tokyodisneyresort.jp/tds/show/detail/7801/"}, {"id": 13, "area": "メディテレーニアンハーバー", "name": "【環境演出】スパークリング・ジュビリー・ナイト", "times": ["20:15", "20:40", "20:55"], "duration": 5, "features": "屋外", "imageUrl": "/assets/show-images/sparkling-jubilee-night.png", "isLottery": false, "description": "東京ディズニーシー・ホテルミラコスタの壁面に映像が映し出され、25周年のテーマソングにのせてきらめきにあふれた世界が繰り広げられます。", "officialUrl": "https://www.tokyodisneyresort.jp/tds/show/detail/7405/"}, {"id": 9, "area": "メディテレーニアンハーバー", "name": "スパークリング・ジュビリー・セレブレーション", "times": ["11:30", "14:00", "16:00"], "duration": 15, "features": "屋外", "imageUrl": "/assets/show-images/sparkling-jubilee-celebration.png", "isLottery": false, "description": "心きらめくジュビリーブルーを基調とした衣装に身を包んだミッキーマウスをはじめとするディズニーの仲間たちが、25周年の装飾で彩られた船に乗り、ゲストの皆さまにごあいさつ。陸上にもディズニーの仲間たちやキャストが登場し、全員が一体となり、盛大にお祝いします。", "officialUrl": "https://www.tokyodisneyresort.jp/tds/show/detail/7404/"}, {"id": 10, "area": "アメリカンウォーターフロント（ウォーターフロントパーク）", "name": "ダンス・ザ・グローブ！", "times": ["13:00", "14:45", "17:05", "18:50"], "duration": 25, "features": "屋外", "imageUrl": "/assets/show-images/dance-the-globe.png", "isLottery": true, "description": "ディズニーの仲間たちが世界のバラエティに富んだスタイルのパフォーマンスを披露し、お互いの文化を称えあう、世界のダンスと音楽の祭典を開催します。フィナーレには、ミッキーマウスたちが東京ディズニーシー25周年の衣装で登場し、華やかな演出とともに盛り上げます。世界のきらめきにあふれた祝祭を、どうぞお楽しみください！", "officialUrl": "https://www.tokyodisneyresort.jp/tds/show/detail/7604/"}, {"id": 11, "area": "ロストリバーデルタ（ハンガーステージ）", "name": "ドリームス・テイク・フライト", "times": ["11:00", "12:25", "13:50", "15:55", "17:20"], "duration": 25, "features": "屋内、雨の日も実施", "imageUrl": "/assets/show-images/dreams-take-flight.png", "isLottery": true, "description": "始業前の工場に、工場長を務めるピートと飛行機づくりに誇りと情熱を注ぐ職人たちが集まると、大忙しの1日が始まります。工場では、ミッキーマウスをはじめとするディズニーの仲間たちが、様々なハプニングを乗り越えながらも、飛行機を作り上げようと力を注ぎます。職人たちが楽しくにぎやかに飛行機を作り上げると、会場は一体感に包まれ、飛行機の完成をお祝いするフィナーレを迎えます。バラエティーに富んだシーン展開と遊び心あふれるパフォーマンスでお届けするエンターテイメントを、どうぞお楽しみください！", "officialUrl": "https://www.tokyodisneyresort.jp/tds/show/detail/7602/"}], "dailySchedules": {"2026-05-11": {"7": ["19:15"], "9": ["11:30", "14:00", "16:00"], "10": ["12:50", "14:35", "16:55", "18:40"], "11": ["11:00", "12:25", "13:50", "15:55", "17:20"], "12": ["20:15"], "13": ["20:00", "20:25", "20:50"]}, "2026-05-12": {"7": ["19:15"], "9": ["11:30", "14:00", "16:00"], "10": ["12:50", "14:35", "16:55", "18:40"], "11": ["11:00", "12:25", "13:50", "15:55", "17:20"], "12": ["20:15"], "13": ["20:00", "20:25", "20:50"]}, "2026-05-13": {"7": ["19:15"], "9": ["11:30", "14:00", "16:00"], "10": ["12:50", "14:35", "16:55", "18:40"], "11": ["11:00", "12:25", "13:50", "15:55", "17:20"], "12": ["20:15"], "13": ["20:00", "20:25", "20:50"]}, "2026-05-14": {"7": ["19:15"], "9": ["11:30", "14:00", "16:00"], "10": ["12:50", "14:35", "16:55", "18:40"], "11": ["11:00", "12:25", "13:50", "15:55", "17:20"], "12": ["20:15"], "13": ["20:00", "20:25", "20:50"]}, "2026-05-15": {"7": ["19:15"], "9": ["11:30", "14:00", "16:00"], "10": ["12:50", "14:35", "16:55", "18:40"], "11": ["11:00", "12:25", "13:50", "15:55", "17:20"], "12": ["20:15"], "13": ["20:00", "20:25", "20:50"]}, "2026-05-16": {"7": ["19:15"], "9": ["11:30", "14:00", "16:00"], "10": ["12:50", "14:35", "16:55", "18:40"], "11": ["11:00", "12:25", "13:50", "15:55", "17:20"], "12": ["20:15"], "13": ["